# Application
APP_ENV=development         
APP_SECRET_KEY=change-me-to-a-random-secret
LOG_LEVEL=INFO

# PostgreSQL
POSTGRES_USER=notiscope
POSTGRES_PASSWORD=notiscope_secret
POSTGRES_DB=notiscope
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://notiscope:notiscope_secret@db:5432/notiscope

#  Redis 
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

#  Celery 
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_MAX_RETRIES=5
CELERY_RETRY_BACKOFF=2          
CELERY_TASK_SOFT_TIME_LIMIT=60 
CELERY_TASK_TIME_LIMIT=90 

# SendGrid (Primary Email Provider) 
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=Notiscope

# AWS SES (Fallback Email Provider) 
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@yourdomain.com


IDEMPOTENCY_KEY_TTL_HOURS=24    
REDIS_LOCK_TTL_SECONDS=30       


DLQ_CHECK_INTERVAL_MINUTES=5
DLQ_FAILED_THRESHOLD_MINUTES=10 # notify if failed for longer than this
